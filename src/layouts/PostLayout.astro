---
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;

// Maps freeform post tags onto the shared categorical badge palette from
// tokens.css, kept consistent with the category chips on nils.ecke.lt.
const TAG_BADGE: Record<string, "cloud" | "ai" | "lang" | "arch" | "lead" | "ux"> = {
  AI: "ai",
  "Software Factory": "arch",
  "Hackers&Wizards": "ai",
};
const badgeFor = (tag: string) => TAG_BADGE[tag] ?? "cloud";
// Mermaid diagrams pick up this post's category color via --diagram-accent.
const primaryBadge = tags.length > 0 ? badgeFor(tags[0]) : "cloud";
---

<BaseLayout title={title} description={description} type="article">
  <article data-badge={primaryBadge}>
    <a href="/" class="back">&larr; Alle Beiträge</a>
    <header class="post-header">
      <div class="post-meta">
        {pubDate && <FormattedDate date={pubDate} />}
        {
          updatedDate && (
            <span>· aktualisiert <FormattedDate date={updatedDate} /></span>
          )
        }
      </div>
      <h1>{title}</h1>
      {
        tags.length > 0 && (
          <ul class="tags">
            {tags.map((tag) => (
              <li class={`tag-${badgeFor(tag)}`}>{tag}</li>
            ))}
          </ul>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>

  <script>
    // Load + render Mermaid only on posts that actually contain a diagram.
    // Waits for the "load" event so the external stylesheet is guaranteed to
    // be applied before Mermaid reads our CSS custom properties — otherwise
    // getComputedStyle can race the stylesheet fetch and Mermaid silently
    // falls back to its own default (purple) theme instead of ours.
    function bootMermaid() {
      if (document.querySelector("pre.mermaid")) {
        import("../scripts/mermaid").then((m) => m.default());
      }
    }
    if (document.readyState === "complete") {
      bootMermaid();
    } else {
      window.addEventListener("load", bootMermaid);
    }
  </script>

  <style>
    .back {
      display: inline-block;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 2.5rem 0 2rem;
      transition: color 0.2s;
    }
    .back:hover {
      color: var(--accent);
    }
    .post-header {
      margin-bottom: 2.5rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--rule);
    }
    .post-meta {
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }
    h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2rem, 6vw, 3rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--text);
    }
    .tags {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1.25rem;
      padding: 0;
    }
    .tags li {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
    }
    .tag-cloud {
      color: var(--badge-cloud);
      background: var(--badge-cloud-bg);
    }
    .tag-ai {
      color: var(--badge-ai);
      background: var(--badge-ai-bg);
    }
    .tag-lang {
      color: var(--badge-lang);
      background: var(--badge-lang-bg);
    }
    .tag-arch {
      color: var(--badge-arch);
      background: var(--badge-arch-bg);
    }
    .tag-lead {
      color: var(--badge-lead);
      background: var(--badge-lead-bg);
    }
    .tag-ux {
      color: var(--badge-ux);
      background: var(--badge-ux-bg);
    }
    article[data-badge="cloud"] {
      --diagram-accent: var(--badge-cloud);
    }
    article[data-badge="ai"] {
      --diagram-accent: var(--badge-ai);
    }
    article[data-badge="lang"] {
      --diagram-accent: var(--badge-lang);
    }
    article[data-badge="arch"] {
      --diagram-accent: var(--badge-arch);
    }
    article[data-badge="lead"] {
      --diagram-accent: var(--badge-lead);
    }
    article[data-badge="ux"] {
      --diagram-accent: var(--badge-ux);
    }
  </style>
</BaseLayout>
