---
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;
---

<BaseLayout title={title} description={description} type="article">
  <article>
    <a href="/" class="back">&larr; Alle Beiträge</a>
    <header class="post-header">
      <div class="post-meta">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <span>· aktualisiert <FormattedDate date={updatedDate} /></span>
          )
        }
      </div>
      <h1>{title}</h1>
      {
        tags.length > 0 && (
          <ul class="tags">
            {tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        )
      }
      <div class="speech-controls">
        <button type="button" id="speech-toggle" class="speech-btn" hidden>
          🔊 Vorlesen
        </button>
        <button type="button" id="speech-stop" class="speech-btn" hidden>
          Stopp
        </button>
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>

  <script>
    // Load + render Mermaid only on posts that actually contain a diagram.
    if (document.querySelector("pre.mermaid")) {
      import("../scripts/mermaid").then((m) => m.default());
    }
    import("../scripts/speech").then((m) => m.default());
  </script>

  <style>
    .back {
      display: inline-block;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 2.5rem 0 2rem;
      transition: color 0.2s;
    }
    .back:hover {
      color: var(--accent);
    }
    .post-header {
      margin-bottom: 2.5rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--rule);
    }
    .post-meta {
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }
    h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(2rem, 6vw, 3rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      color: var(--text);
    }
    .tags {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1.25rem;
      padding: 0;
    }
    .tags li {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--accent);
      background: var(--badge-cloud-bg);
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
    }
    .speech-controls {
      display: flex;
      gap: 0.5rem;
      margin-top: 1.25rem;
    }
    .speech-btn {
      font: inherit;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--text);
      background: var(--surface);
      border: 1px solid var(--rule);
      border-radius: 999px;
      padding: 0.35rem 0.9rem;
      cursor: pointer;
      transition:
        border-color 0.2s,
        color 0.2s;
    }
    .speech-btn:hover {
      color: var(--accent);
      border-color: var(--accent);
    }
  </style>
</BaseLayout>
