---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout>
  <section class="intro">
    <p class="label">Blog</p>
    <h1>Gedanken zu Agentic Product Development, Engineering&nbsp;Transformation und Cloud.</h1>
  </section>

  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`} class="post-item">
            <div class="post-date">
              <FormattedDate date={post.data.pubDate} />
            </div>
            <div class="post-body">
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </div>
            <span class="post-arrow" aria-hidden="true">&#8250;</span>
          </a>
        </li>
      ))
    }
    {
      posts.length === 0 && (
        <li class="empty">Noch keine Beiträge — bald geht's los.</li>
      )
    }
  </ul>

  <style>
    .intro {
      padding: 3rem 0;
      border-bottom: 1px solid var(--rule);
    }
    .intro h1 {
      font-family: var(--font-heading);
      font-weight: 800;
      font-size: clamp(1.9rem, 5.5vw, 2.8rem);
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--text);
    }
    .post-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .post-list > li {
      border-bottom: 1px solid var(--rule);
    }
    .post-item {
      display: grid;
      grid-template-columns: 8.5rem 1fr auto;
      gap: 0 1.5rem;
      align-items: baseline;
      padding: 2rem 0;
      color: inherit;
    }
    .post-date {
      font-size: 0.78rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--muted);
      padding-top: 0.2rem;
    }
    .post-body h2 {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: 1.35rem;
      line-height: 1.2;
      letter-spacing: -0.02em;
      color: var(--text);
      transition: color 0.2s;
    }
    .post-body p {
      margin-top: 0.4rem;
      color: var(--muted);
      font-size: 0.95rem;
    }
    .post-arrow {
      color: var(--accent);
      font-size: 1.4rem;
      opacity: 0;
      transform: translateX(-0.3rem);
      transition:
        opacity 0.2s,
        transform 0.2s;
    }
    .post-item:hover .post-body h2 {
      color: var(--accent);
    }
    .post-item:hover .post-arrow {
      opacity: 1;
      transform: translateX(0);
    }
    .empty {
      padding: 3rem 0;
      color: var(--muted);
    }
    @media (max-width: 560px) {
      .post-item {
        grid-template-columns: 1fr;
        gap: 0.5rem;
      }
      .post-arrow {
        display: none;
      }
    }
  </style>
</BaseLayout>
