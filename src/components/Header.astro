---
import { NAV } from "../consts";
const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="wrap header-inner">
    <a href="/" class="brand">Nils&nbsp;Eckelt<span class="brand-slash">/</span>Blog</a>
    <nav aria-label="Hauptnavigation">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={["nav-link", { active: item.href === path }]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
  }
  .header-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem 2rem;
    flex-wrap: wrap;
    padding: 2rem 0 1.5rem;
  }
  .brand {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: -0.03em;
    color: var(--text);
  }
  .brand-slash {
    color: var(--accent);
    margin: 0 0.1em;
  }
  nav {
    display: flex;
    gap: 1.4rem;
    flex-wrap: wrap;
  }
  .nav-link {
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--accent);
  }
</style>
